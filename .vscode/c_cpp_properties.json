{
  "configurations": [
    {
      "name": "Mac",
      "includePath": [
        "${workspaceFolder}/**",
        "${env:HOME}/Library/Arduino15/libraries/**",
        "${env:HOME}/Library/Arduino15/packages/**"
      ],
      "defines": [
        "ARDUINO",
        "ESP32"
      ],
      "compilerPath": "/usr/bin/clang",
      "intelliSenseMode": "macos-clang-x64",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${env:HOME}/Library/Arduino15/libraries",
          "${env:HOME}/Library/Arduino15/packages"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ],
  "version": 4
}